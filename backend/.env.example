# BodaSOS Backend – Environment Variables
# Copy to .env and fill in real values

# ── Database ──────────────────────────────────
DATABASE_PATH=bodasos.db

# ── Twilio (get free trial at twilio.com) ─────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+12025551234

# ── Security ──────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-this-to-a-random-64-char-hex-string

# Separate key for admin-only endpoints (/sos_history)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=change-this-to-another-random-64-char-hex-string

# Comma-separated allowed CORS origins (use * only in development)
# Production example: https://bodasos.app,https://admin.bodasos.app
ALLOWED_ORIGINS=*

# ── Alert Radii ───────────────────────────────
SOS_RADIUS_KM=5.0
REPAIR_RADIUS_KM=5.0

# ── Server ────────────────────────────────────
PORT=5000
FLASK_DEBUG=false

# ── Firebase Cloud Messaging (optional — free push notifications) ─────────────
# 1. Create project at console.firebase.google.com
# 2. Add Android app, download google-services.json → android/app/
# 3. Get Server Key from Project Settings > Cloud Messaging
FIREBASE_SERVER_KEY=
